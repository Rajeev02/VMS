{
  "expo": {
    "name": "VMS",
    "slug": "VMS",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icons/ios/AppIcon~ios-marketing.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.github.rajeev02.vms",
      "infoPlist": {
        "NSCameraUsageDescription": "The app needs access to your camera to scan QR code visitor passes."
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "icon": "./icons/android/play_store_512.png",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./icons/android/play_store_512.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "googleServicesFile": "./google-services.json",
      "package": "io.github.rajeev02.vms"
    },
    "web": {
      "favicon": "./icons/web/favicon.ico"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "expo-secure-store",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "The app needs access to your camera to scan QR code visitor passes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to let you select a QR code pass from your gallery.",
          "cameraPermission": "The app needs access to your camera to take a picture of the ID and visitor."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4",
            "useFrameworks": "static"
          }
        }
      ]
    ]
  }
}
