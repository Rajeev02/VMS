rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    match /visitors/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /public/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
